      <data key="d1">PERSON</data>
      <data key="d6">Pierre Curie</data>
      <data key="d7">Pierre Curie was a physicist and the husband of Marie Curie. He shared the 1903 Nobel Prize in Physics with Marie Curie and Henri Becquerel for their work on radioactivity.</data>
      <data key="d9">0.016394</data>
      <data key="d10">1.0</data>
      <data key="d11" />
    </node>
    <node id="entity:e27165f1ae951a05643c">
