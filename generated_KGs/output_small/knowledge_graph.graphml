    <node id="entity:cd712ce88bce4bbc4740">
      <data key="d0">entity:cd712ce88bce4bbc4740</data>
      <data key="d1">CONCEPT</data>
      <data key="d6">Turing Test</data>
      <data key="d7">The Turing Test is a test of a machine's ability to exhibit intelligent behavior equivalent to, or indistinguishable from, that of a human. It was introduced by Alan Turing in his 1950 paper, "Computing Machinery and Intelligence."</data>
      <data key="d9">0.011279</data>
      <data key="d10">1.0</data>
      <data key="d11" />
    </node>
