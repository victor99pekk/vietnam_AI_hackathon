    <node id="entity:e11aa880be5576adeab0">
      <data key="d0">entity:e11aa880be5576adeab0</data>
      <data key="d1">SCIENCE</data>
      <data key="d6">radioactivity</data>
      <data key="d7">Radioactivity is the phenomenon of spontaneous emission of radiation. Pioneering research on this phenomenon was conducted by Marie Curie, who, along with Pierre Curie and Henri Becquerel, was recognized for this work.</data>
      <data key="d9">0.056167</data>
      <data key="d10">1.0</data>
      <data key="d11" />
    </node>
    <node id="entity:ae7590a26638946f46bb">
      <data key="d0">entity:ae7590a26638946f46bb</data>
      <data key="d1">SCIENCE</data>
      <data key="d6">polonium</data>
      <data key="d7">Polonium is a radioactive chemical element discovered by Marie Curie, who named it after her native Poland.</data>
      <data key="d9">0.009401</data>
      <data key="d10">1.0</data>
      <data key="d11" />
    </node>
    <node id="entity:5278405a24ef270d45e8">
      <data key="d0">entity:5278405a24ef270d45e8</data>
      <data key="d1">SCIENCE</data>
      <data key="d6">radium</data>
      <data key="d7">Radium is a radioactive chemical element discovered by Marie Curie, a groundbreaking achievement that contributed to her winning a second Nobel Prize.</data>
      <data key="d9">0.011004</data>
      <data key="d10">1.0</data>
      <data key="d11" />
    </node>
