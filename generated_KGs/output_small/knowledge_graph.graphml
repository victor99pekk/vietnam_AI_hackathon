    <node id="entity:47f3cbe05995ca034577">
      <data key="d0">entity:47f3cbe05995ca034577</data>
      <data key="d1">EVENT</data>
      <data key="d6">Nobel Prize in Physics</data>
      <data key="d7">The Nobel Prize in Physics is a prestigious award that was received jointly by Marie Curie, Pierre Curie, and Henri Becquerel in 1903. They were recognized for their collective work on radioactivity.</data>
      <data key="d9">0.094525</data>
      <data key="d10">1.0</data>
      <data key="d11" />
    </node>
    <node id="entity:22d9b9b89e9481d9f666">
