      <data key="d1">PERSON</data>
      <data key="d6">Henri Becquerel</data>
      <data key="d7">Henri Becquerel was a physicist who shared the 1903 Nobel Prize in Physics with Marie and Pierre Curie for their collective work on radioactivity, including his discovery of spontaneous radioactivity.</data>
      <data key="d9">0.018725</data>
      <data key="d10">1.0</data>
      <data key="d11" />
    </node>
