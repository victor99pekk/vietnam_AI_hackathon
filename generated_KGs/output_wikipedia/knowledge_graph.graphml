      <data key="d3">PERSON</data>
      <data key="d8">Maspéro</data>
      <data key="d9">Nhà nghiên cứu đưa ra ước lượng về tỷ lệ từ Hán Việt trong tiếng Việt.</data>
      <data key="d11">0.001562</data>
