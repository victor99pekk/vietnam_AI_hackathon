      <data key="d8">Tòa Bạch Ốc</data>
      <data key="d9">Tên riêng phương Tây (Nhà Trắng) được phiên âm qua từ Hán Việt.</data>
      <data key="d11">0.001609</data>
      <data key="d12">1.0</data>
