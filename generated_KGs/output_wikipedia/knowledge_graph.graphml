    <node id="entity:0d2a53923943e8770f8d">
      <data key="d2">entity:0d2a53923943e8770f8d</data>
      <data key="d3">PERSON</data>
      <data key="d8">Hoàng Trọng Phiến</data>
      <data key="d9">Một trong ba tác giả của cuốn sách Cơ sở ngôn ngữ học và tiếng Việt.</data>
