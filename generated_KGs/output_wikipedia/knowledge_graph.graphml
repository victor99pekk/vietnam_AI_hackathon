    <node id="entity:8598eb9929e76a2ea0a7">
      <data key="d2">entity:8598eb9929e76a2ea0a7</data>
      <data key="d3">CONCEPT</data>
      <data key="d8">Tắc</data>
      <data key="d9">Loại phụ âm tắc trong tiếng Việt, gồm thường, thanh hầu hóa và bật hơi.</data>
      <data key="d11">0.001791</data>
