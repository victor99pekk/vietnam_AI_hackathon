      <data key="d14">["MENTIONS"]</data>
      <data key="d15">1</data>
      <data key="d16">["Còn các nhà cải cách Việt Nam ủng hộ việc truyền bá hệ chữ Latinh như phương tiện để khai dân trí, chấn dân khí."]</data>
