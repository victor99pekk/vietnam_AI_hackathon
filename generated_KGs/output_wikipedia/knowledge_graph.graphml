    <edge source="chunk:d0743e97d5182099dd0a" target="entity:2a8b256a85c3e1286e2a">
      <data key="d14">["MENTIONS"]</data>
      <data key="d15">1</data>
      <data key="d16">["Phần lớn các văn bản hành chính tiếng Việt ở Việt Nam được viết bằng chữ Quốc ngữ theo \"Quy định về chính tả tiếng Việt và về thuật ngữ tiếng Việt\" áp dụng cho các sách giáo khoa, báo và văn bản của ngành giáo dục, nêu tại Quyết định của Bộ Giáo dục số 240/QĐ ngày 5 tháng 3 năm 1984 do những người thụ hưởng giáo dục đó sau này ra làm việc trong mọi lĩnh vực xã hội hướng tới việc chuẩn hóa chính tả tiếng Việt."]</data>
      <data key="d17">["chunk:d0743e97d5182099dd0a"]</data>
