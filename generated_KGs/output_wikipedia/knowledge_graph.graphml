    <node id="entity:19bea24d0c24dd37d0b7">
      <data key="d2">entity:19bea24d0c24dd37d0b7</data>
      <data key="d3">KEYWORD</data>
      <data key="d8">Đực</data>
      <data key="d9">Một tên thông tục phổ biến ở miền Nam Việt Nam trước 1960.</data>
      <data key="d11">0.001585</data>
      <data key="d12">1.0</data>
