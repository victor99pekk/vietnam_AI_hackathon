      <data key="d2">entity:4cbd9a2e6018e596e2c2</data>
      <data key="d3">ORGANIZATION</data>
      <data key="d8">các cấp quản lý</data>
      <data key="d9">Các cấp chính quyền tham gia quản lý ngôn ngữ.</data>
      <data key="d11">0.001562</data>
      <data key="d12">1.0</data>
      <data key="d13" />
    </node>
