      <data key="d2">entity:c6365f7210958b0e9372</data>
      <data key="d3">KEYWORD</data>
      <data key="d8">tự do</data>
      <data key="d9">Một yếu tố Hán-Việt giữ nguyên nghĩa, chỉ khác cách đọc.</data>
