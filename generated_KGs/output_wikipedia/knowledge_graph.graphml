      <data key="d2">entity:59ca2d72623c77c71264</data>
      <data key="d3">CONCEPT</data>
      <data key="d8">giao tiếp tiếng Việt qua mạng</data>
      <data key="d9">Hoạt động giao tiếp bằng tiếng Việt trên mạng internet.</data>
      <data key="d11">0.001578</data>
      <data key="d12">1.0</data>
      <data key="d13" />
    </node>
    <node id="entity:10eb29bfde3a1426774e">
      <data key="d2">entity:10eb29bfde3a1426774e</data>
      <data key="d3">CONCEPT</data>
      <data key="d8">bảng chữ cái tiếng Anh</data>
      <data key="d9">Bảng chữ cái gồm 26 ký tự không dấu, dùng làm cơ sở so sánh.</data>
      <data key="d11">0.001578</data>
      <data key="d12">1.0</data>
      <data key="d13" />
    </node>
    <node id="entity:9a853873dce4e6cea0fe">
      <data key="d2">entity:9a853873dce4e6cea0fe</data>
      <data key="d3">CONCEPT</data>
      <data key="d8">ký tự có dấu</data>
      <data key="d9">Các ký tự đặc biệt trong chữ Quốc ngữ, gồm Ă, Â, Đ, Ê, Ô, Ơ, Ư và nguyên âm mang thanh điệu.</data>
      <data key="d11">0.002828</data>
      <data key="d12">1.0</data>
      <data key="d13" />
    </node>
    <node id="entity:4ea4090649e22baa5149">
      <data key="d2">entity:4ea4090649e22baa5149</data>
      <data key="d3">ARTIFICIAL</data>
      <data key="d8">máy tính</data>
      <data key="d9">Dưới đây là bản tổng hợp đầy đủ từ dữ liệu đã cho:

**Thực thể: máy tính**

Máy tính là thiết bị điện tử dùng để soạn thảo văn bản và xử lý thông tin. Để có thể viết tiếng Việt trên thiết bị này, người dùng cần nạp thêm các ký tự hoặc bộ gõ tiếng Việt phù hợp.</data>
      <data key="d11">0.006158</data>
      <data key="d12">1.0</data>
      <data key="d13" />
    </node>
    <node id="entity:a119d195b995fddfe8aa">
      <data key="d2">entity:a119d195b995fddfe8aa</data>
      <data key="d3">ARTIFICIAL</data>
      <data key="d8">điện thoại di động</data>
      <data key="d9">**Thực thể: điện thoại di động**

Điện thoại di động là một thiết bị di động hỗ trợ soạn thảo văn bản và nhắn tin. Tuy nhiên, để viết tiếng Việt trên thiết bị này, người dùng cần nạp thêm ký tự (ví dụ: cài đặt bộ gõ tiếng Việt hoặc bổ sung font chữ hỗ trợ dấu).</data>
      <data key="d11">0.006158</data>
      <data key="d12">1.0</data>
      <data key="d13" />
    </node>
    <node id="entity:ee9bbe0bda0043fe4048">
      <data key="d2">entity:ee9bbe0bda0043fe4048</data>
      <data key="d3">TECHNOLOGY</data>
      <data key="d8">phông chữ Quốc ngữ</data>
      <data key="d9">Phông chữ hỗ trợ hiển thị các ký tự tiếng Việt có dấu.</data>
      <data key="d11">0.012562</data>
      <data key="d12">1.0</data>
      <data key="d13" />
    </node>
    <node id="entity:23ec7f37b82b19fe9ddf">
      <data key="d2">entity:23ec7f37b82b19fe9ddf</data>
      <data key="d3">TECHNOLOGY</data>
      <data key="d8">bộ gõ</data>
      <data key="d9">Phần mềm hỗ trợ soạn thảo văn bản tiếng Việt trên máy tính và điện thoại.</data>
      <data key="d11">0.008179</data>
      <data key="d12">1.0</data>
      <data key="d13" />
    </node>
    <node id="entity:12ca2951e8cd59f3dbd7">
      <data key="d2">entity:12ca2951e8cd59f3dbd7</data>
      <data key="d3">TECHNOLOGY</data>
      <data key="d8">phần mềm</data>
      <data key="d9">Công cụ hỗ trợ soạn thảo và hiển thị văn bản tiếng Việt.</data>
      <data key="d11">0.001592</data>
      <data key="d12">1.0</data>
      <data key="d13" />
    </node>
