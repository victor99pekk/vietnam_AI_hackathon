      <data key="d8">tổ chức xã hội - nghề nghiệp</data>
      <data key="d9">Các tổ chức xã hội và nghề nghiệp liên quan đến ngôn ngữ.</data>
      <data key="d11">0.001562</data>
      <data key="d12">1.0</data>
