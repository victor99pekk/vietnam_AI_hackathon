      <data key="d14">["MENTIONS"]</data>
      <data key="d15">1</data>
      <data key="d16">["Hiệp vần cũng có điểm đặc biệt, tức là vần lưng (yêu vận, vần giữa câu)."]</data>
      <data key="d17">["chunk:16f2ae8ef7c114cc8363"]</data>
