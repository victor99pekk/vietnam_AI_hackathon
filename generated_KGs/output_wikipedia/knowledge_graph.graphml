      <data key="d3">DATE</data>
      <data key="d8">năm 1887</data>
      <data key="d9">Năm ký kết Công ước Pháp-Thanh.</data>
      <data key="d11">0.00227</data>
      <data key="d12">1.0</data>
      <data key="d13" />
    </node>
    <node id="entity:d192962ef6aace1264e2">
      <data key="d2">entity:d192962ef6aace1264e2</data>
      <data key="d3">ORGANIZATION</data>
      <data key="d8">Đại Thanh</data>
      <data key="d9">Triều đại phong kiến Trung Quốc, có lãnh thổ bao gồm Đông Hưng sau Công ước Pháp-Thanh.</data>
      <data key="d11">0.00227</data>
      <data key="d12">1.0</data>
      <data key="d13" />
    </node>
    <node id="entity:62a108dad1d23fd77045">
      <data key="d2">entity:62a108dad1d23fd77045</data>
      <data key="d3">WORK</data>
      <data key="d8">Hiến pháp nước Cộng hòa xã hội chủ nghĩa Việt Nam 2013</data>
      <data key="d9">**Hiến pháp nước Cộng hòa xã hội chủ nghĩa Việt Nam 2013** là văn bản pháp lý cao nhất của Việt Nam, được ban hành năm 2013. Văn bản hiến pháp này quy định tiếng Việt là ngôn ngữ quốc gia.</data>
      <data key="d11">0.001681</data>
      <data key="d12">1.0</data>
      <data key="d13" />
    </node>
    <node id="entity:fa0815d696a0d1e83ae2">
      <data key="d2">entity:fa0815d696a0d1e83ae2</data>
      <data key="d3">CONCEPT</data>
      <data key="d8">Chương I Điều 5 Mục 3</data>
      <data key="d9">Phần cụ thể trong Hiến pháp 2013 quy định về ngôn ngữ quốc gia.</data>
      <data key="d11">0.001598</data>
      <data key="d12">1.0</data>
      <data key="d13" />
    </node>
    <node id="entity:d92a9b8f15c9bfbc7577">
      <data key="d2">entity:d92a9b8f15c9bfbc7577</data>
      <data key="d3">ORGANIZATION</data>
      <data key="d8">Bộ Giáo dục</data>
      <data key="d9">Cơ quan nhà nước ban hành Quyết định số 240/QĐ về chính tả tiếng Việt.</data>
      <data key="d11">0.002271</data>
      <data key="d12">1.0</data>
      <data key="d13" />
    </node>
    <node id="entity:69b597674fa8e941ea91">
      <data key="d2">entity:69b597674fa8e941ea91</data>
      <data key="d3">EVENT</data>
      <data key="d8">Quyết định số 240/QĐ ngày 5 tháng 3 năm 1984</data>
      <data key="d9">Quyết định của Bộ Giáo dục về quy định chính tả tiếng Việt, có hiệu lực từ năm 1984.</data>
      <data key="d11">0.001598</data>
      <data key="d12">1.0</data>
      <data key="d13" />
    </node>
