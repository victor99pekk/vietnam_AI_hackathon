    <edge source="chunk:6aa4030fdab9de4f2033" target="entity:71892354c36df96c1276">
      <data key="d14">["MENTIONS"]</data>
      <data key="d15">1</data>
      <data key="d16">["Tác giả Lê Nguyễn Lưu trong cuốn sách Từ chữ Hán đến chữ Nôm thì cho rằng về lĩnh vực chuyên môn và khoa học tỉ lệ này có thể lên đến 80% nhưng khi nhận xét về văn ngữ trong một cuốn tiểu thuyết thì chỉ còn 12,8%, kịch nói rút xuống còn 8,9% và ngôn ngữ nói chuyện hằng ngày còn thấp hơn nữa."]</data>
