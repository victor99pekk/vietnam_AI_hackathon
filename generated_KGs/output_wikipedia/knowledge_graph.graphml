    <edge source="chunk:16f2ae8ef7c114cc8363" target="entity:9d5854879313b32b5e25">
      <data key="d14">["MENTIONS"]</data>
      <data key="d15">1</data>
      <data key="d16">["Trần Văn Giáp đánh giá đây tuy chỉ là quyển sách dạy học vỡ lòng về chữ Hán như đã nêu ở trên nhưng thực ra cũng có thể coi nó chính là sách Từ điển Hán Việt thông thường và phổ biến ở cuối thế kỷ XVIII, cùng thời với các sách Chỉ nam ngọc âm, Chỉ nam bị loại và xuất hiện trước các sách Nhật dụng thường đàm, Thiên tự văn và Đại Nam quốc ngữ."]</data>
      <data key="d17">["chunk:16f2ae8ef7c114cc8363"]</data>
