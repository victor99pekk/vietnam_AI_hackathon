    <edge source="chunk:1c1b5f0719eb4ab793c0" target="entity:11ff4cd3361d34fb3043">
      <data key="d14">["MENTIONS"]</data>
      <data key="d15">1</data>
      <data key="d16">["Tại miền Bắc (Việt Nam Dân chủ Cộng hòa) có xu hướng chuyển sang sử dụng từ thuần Việt thay thế từ Hán Việt cùng nghĩa còn ở miền Nam (Việt Nam Cộng hòa) thì vẫn giữ nguyên việc sử dụng từ Hán Việt như thời trước 1945."]</data>
