    <edge source="marie_curie:chunk0" target="Marie Curie">
      <data key="d15">["MENTIONS"]</data>
      <data key="d16">1</data>
      <data key="d17">["Marie Curie was born in Warsaw, Poland in 1867. She is best known for her pioneering research on radioactivity. She discovered the elements polonium and radium.\n\nCurie worked at the University of Paris, where she became the first female professor. In 1903, she received the Nobel Prize in Physics along with Pierre Curie and Henri Becquerel for their work on radioactivity."]</data>
    </edge>
