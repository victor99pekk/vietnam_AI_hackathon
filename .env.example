# DeepSeek API key (for LLM-based extraction)
# Get yours at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-key-here

# Neo4j Desktop connection (for graph_backend: neo4j)
# Default: bolt://localhost:7687 with user neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password-here

