# DeepSeek API key (for LLM-based extraction)
# Get yours at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-key-here

# Separate Neo4j instances/databases for the global read graph and interactive
# pipeline writes. Aura uses neo4j+s:// URIs.
NEO4J_GLOBAL_URI=neo4j+s://global-instance.databases.neo4j.io
NEO4J_GLOBAL_DATABASE=neo4j
NEO4J_GLOBAL_USER=neo4j
NEO4J_GLOBAL_PASSWORD=your-global-password-here
NEO4J_INTERACTIVE_URI=neo4j+s://interactive-instance.databases.neo4j.io
NEO4J_INTERACTIVE_DATABASE=interactive
NEO4J_INTERACTIVE_USER=interactive-writer
NEO4J_INTERACTIVE_PASSWORD=your-interactive-password-here

# Optional local-only workaround for a TLS-intercepting network. Keep false or
# unset when the machine has a valid CA trust chain.
# NEO4J_TRUST_ALL_CERTIFICATES=false
