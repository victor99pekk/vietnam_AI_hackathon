# DeepSeek API key (for LLM-based extraction)
# Get yours at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-key-here

# One Neo4j server, isolated global and interactive databases.
NEO4J_URI=bolt://localhost:7687
NEO4J_GLOBAL_DATABASE=neo4j
NEO4J_GLOBAL_USER=global-reader
NEO4J_GLOBAL_PASSWORD=your-read-only-password-here
NEO4J_INTERACTIVE_DATABASE=interactive
NEO4J_INTERACTIVE_USER=interactive-writer
NEO4J_INTERACTIVE_PASSWORD=your-write-password-here
